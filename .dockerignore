# Keeps the build context (and image) small. Without this, `COPY . .` bakes
# the local virtualenv and eval artifacts into the image.
.venv/
venv/
.git/
.github/

__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Evaluation output — regenerated by eval_harness.py, never needed at runtime
results/

# Docs / assets — not used by the service
docs/
scripts/
RUNBOOK.md
EVALUATION.md

# The unquantized export is ~738 MB and is never loaded: tier2_classifier.py
# pins file_name="model_quantized.onnx". Keep only the quantized graph.
models/**/model.onnx

*.log
.env
.DS_Store
