# Keeps the build context (and image) small. Without this, `COPY . .` bakes
# the local virtualenv and eval artifacts into the image.
.venv/
venv/
.git/
.github/

__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Evaluation output — regenerated by eval_harness.py, never needed at runtime
results/

# Docs / assets — not used by the service
docs/
scripts/
RUNBOOK.md
EVALUATION.md

# Tier 2 loads models/deberta-v3-onnx/model.onnx (fp32) by default — INT8
# quantization costs ~14-17 points of recall on this model, so the fp32 graph
# must stay in the image. Exclude the INT8 variants instead; set
# GUARDRAIL_TIER2_MODEL_FILE and drop these lines if you want to ship INT8.
models/**/model_quantized*.onnx

*.log
.env
.DS_Store
